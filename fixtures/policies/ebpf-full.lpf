# eBPF comprehensive E2E test policy.
# Exercises every feature the eBPF datapath supports:
#   - default deny with pass/block rules
#   - CIDR table membership (source + destination)
#   - Protocol-specific rules (tcp, udp, icmp)
#   - Port ranges
#   - Multiple interfaces
#   - Direction parity (in, out)
#   - Rule precedence (first-match)
#   - Anchors for reusable rule chains
#   - Identity selectors (cgroup, proc, dns tables via underscore names)

set default deny

# ── tables ─────────────────────────────────────────────────────────────────

table <trusted> { 10.0.0.0/8, 192.168.0.0/16, 172.16.0.0/12 }
table <banned> { 1.2.3.0/24, 5.6.7.0/24 }
table <web_servers> { 10.0.0.10, 10.0.0.11 }
table <dns_servers> { 10.0.0.53 }
table <egress_allowed> { 8.8.8.8, 1.1.1.1 }
table <cgroup_webapp> { 10.1.0.0/16 }
table <proc_nginx> { 10.2.0.0/16 }
table <dns_api_gateway> { 10.3.0.0/16 }

# ── interfaces ─────────────────────────────────────────────────────────────

interface wan = "eth0"
interface lan = "eth1"

# ── anchors ────────────────────────────────────────────────────────────────

anchor admin_access {
  pass in on wan proto tcp from <trusted> to <web_servers> port 22
  pass in on wan proto tcp from <trusted> to <dns_servers> port 22
}

anchor web_traffic {
  pass in on wan proto tcp from any to <web_servers> port 80
  pass in on wan proto tcp from any to <web_servers> port 443
}

# ── rules ──────────────────────────────────────────────────────────────────

# Block known-banned sources/destinations first (global)
block in from <banned> to any
block out from any to <banned>

# Admin SSH from trusted IPs (anchor)
admin_access

# Web traffic ingress (anchor)
web_traffic

# DNS ingress (UDP only)
pass in on wan proto udp from any to <dns_servers> port 53

# DNS ingress (TCP fallback)
pass in on wan proto tcp from any to <dns_servers> port 53

# Egress: trusted hosts can reach allowed destinations on common ports
pass out on wan proto tcp from <trusted> to <egress_allowed> port 80
pass out on wan proto tcp from <trusted> to <egress_allowed> port 443
pass out on wan proto tcp from <trusted> to <egress_allowed> port 22
pass out on wan proto udp from <trusted> to <egress_allowed> port 53

# ICMP from trusted sources
pass in on wan proto icmp from <trusted> to any
pass out on wan proto icmp from any to <egress_allowed>

# LAN interface: trusted sources can reach any destination
pass in on lan proto tcp from <trusted> to any
pass in on lan proto udp from <trusted> to any
pass in on lan proto icmp from <trusted> to any

# Identity-based rules (cgroup, proc, dns — underscore prefix parsed by ebpf.ml)
pass out on wan proto tcp from <cgroup_webapp> to any port 80
pass out on wan proto tcp from <cgroup_webapp> to any port 443
pass out on wan proto tcp from <proc_nginx> to any port 80
pass out on wan proto tcp from <proc_nginx> to any port 443
pass out on wan proto tcp from any to <dns_api_gateway> port 443

# Policy-based routing (reserved — route-to compilation)
pass in on lan proto tcp from 10.0.0.55 to <egress_allowed> port 80
pass in on lan proto tcp from 10.0.0.55 to <egress_allowed> port 443

# Implicit block-everything-else (default deny)
