# Copy to .env, .env.local, .env.ci, or .env.jenkins on the Jenkins worker.
# These files are gitignored; do not commit lab endpoints or credential IDs.

VAGABOND_API_URL=
VAGABOND_CREDENTIALS_ID=
SCAN_TARGET=

# Optional extended grep -E pattern for private lab hosts, IPs, or key names
# that must not appear in tracked files.
LPF_FORBIDDEN_GREP_PATTERN=
