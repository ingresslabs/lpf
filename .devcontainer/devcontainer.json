{
  "name": "lpf",
  "build": {
    "dockerfile": "../Dockerfile",
    "target": "builder"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform"
      ]
    }
  },
  "remoteUser": "opam",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-opam,target=/home/opam/.opam,type=volume"
  ]
}
